[Defines]
  INF_VERSION    = 0x00010005
  BASE_NAME      = TlsLibUnitTestHost
  FILE_GUID      = 7A2E4E6F-3B8D-4C1A-9F5E-2D6B8C0A1E3F
  MODULE_TYPE    = HOST_APPLICATION
  VERSION_STRING = 1.0

[Sources]
  UnitTestMainHost.c
  TlsLibUnitTests.c
  TestTlsLib.h
  TlsFunctionPointerTests.c
  TlsContextTests.c
  TlsCipherTests.c
  TlsConfigTests.c
  TlsCertificateTests.c
  TlsGetterTests.c

[Packages]
  MdePkg/MdePkg.dec
  CryptoPkg/CryptoPkg.dec

[LibraryClasses]
  BaseLib
  BaseMemoryLib
  DebugLib
  BaseCryptLib
  TlsLib
  UnitTestLib
  MemoryAllocationLib
